    Action(run_command_and_log, varlist=["TEST_CMD"]),
    TEST_CMD=["./scripts/godot.sh", "--no-auto", "--rendering-method", "mobile", "-s", "addons/godot-gaze/tests/camera_exit_test.gd"]
