# tests/SConscript
# Child SConscript defining all test compilation and execution targets.

Import("core_env env library target_lib gaze_variant_dir")

platform_str = env["platform"]
if env["platform"] == "ios" and env.get("ios_simulator", False):
    platform_str = "ios.simulator"

import os
import sys
import atexit

# Ensure output directories exist
os.makedirs("build/tests/logs", exist_ok=True)
os.makedirs("build/tests/artifacts", exist_ok=True)

# Track executed tests for the final summary printout
executed_tests = []

def exit_summary():
    if not executed_tests:
        return
        
    print("\n" + "="*50)
    print("               TEST SUITE SUMMARY")
    print("="*50)
    
    any_failed = False
    is_tty = sys.stdout.isatty()
    
    for log_path in executed_tests:
        status_path = log_path + ".status"
        
        # e.g., build/tests/logs/tests.native.log -> tests/native
        base = os.path.basename(log_path)
        parts = base.replace("tests.", "").replace(".log", "").split(".")
        alias_name = "tests/" + "/".join(parts)
        
        status_str = "PENDING"
        if os.path.exists(status_path):
            with open(status_path, "r") as sf:
                exit_code = sf.read().strip()
            if exit_code == "0":
                status_str = "\033[92mPASSED\033[0m" if is_tty else "PASSED"
            else:
                status_str = "\033[91mFAILED\033[0m" if is_tty else "FAILED"
                any_failed = True
        else:
            any_failed = True
            
        print(f" {alias_name:<25} : {status_str}")
        
    print("="*50 + "\n")

atexit.register(exit_summary)

# Helper function to run process, log to file, and mirror to terminal in real-time
def run_command_and_log(target, source, env):
    import subprocess
    import sys
    
    log_path = str(target[0])
    executed_tests.append(log_path)
    
    cmd = env.get("TEST_CMD")
    if not cmd:
        print("Error: TEST_CMD is missing in SCons command environment.")
        return 1
        
    print(f"\n[SCons Test] Executing: {' '.join(cmd)}")
    
    # Configure platform-specific library loading paths
    run_env = os.environ.copy()
    bin_dir = os.path.abspath("project/addons/godot-gaze/bin")
    if sys.platform == "darwin":
        existing_dyld = run_env.get("DYLD_LIBRARY_PATH", "")
        if existing_dyld:
            run_env["DYLD_LIBRARY_PATH"] = bin_dir + os.pathsep + existing_dyld
        else:
            run_env["DYLD_LIBRARY_PATH"] = bin_dir
    elif sys.platform == "win32":
        run_env["PATH"] = bin_dir + os.pathsep + run_env.get("PATH", "")
    else:
        existing_ld = run_env.get("LD_LIBRARY_PATH", "")
        if existing_ld:
            run_env["LD_LIBRARY_PATH"] = bin_dir + os.pathsep + existing_ld
        else:
            run_env["LD_LIBRARY_PATH"] = bin_dir
        
    import shutil
    resolved_cmd = list(cmd)
    if resolved_cmd and not os.path.isabs(resolved_cmd[0]):
        path_dirs = run_env.get("PATH", "").split(os.pathsep)
        found_bin = None
        for p in path_dirs:
            if "shims" in p:
                continue
            cand = os.path.join(p, resolved_cmd[0])
            if os.path.isfile(cand) and os.access(cand, os.X_OK):
                found_bin = cand
                break
        if not found_bin:
            home = os.path.expanduser("~")
            known_dirs = [
                os.path.join(home, ".pyenv/versions/3.14.4/bin"),
                os.path.join(home, ".asdf/installs/nodejs/18.12.1/bin"),
                "/opt/homebrew/bin",
                "/usr/local/bin"
            ]
            for p in known_dirs:
                cand = os.path.join(p, resolved_cmd[0])
                if os.path.isfile(cand) and os.access(cand, os.X_OK):
                    found_bin = cand
                    break
        if not found_bin:
            found_bin = shutil.which(resolved_cmd[0], path=run_env.get("PATH"))
        if found_bin:
            resolved_cmd[0] = found_bin

    try:
        process = subprocess.Popen(
            resolved_cmd,
            env=run_env,
            cwd=os.path.abspath("."),
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            text=True
        )
        
        with open(log_path, "w") as log_file:
            for line in process.stdout:
                sys.stdout.write(line)
                log_file.write(line)
                
        process.wait()
        
        # Save exit code to status file
        with open(log_path + ".status", "w") as sf:
            sf.write(str(process.returncode))
            
        if process.returncode != 0:
            print(f"[SCons Test] Failure: Command exited with code {process.returncode}")
            return process.returncode
    except Exception as e:
        error_msg = f"Failed to execute test subprocess: {e}\n"
        sys.stderr.write(error_msg)
        with open(log_path, "w") as log_file:
            log_file.write(error_msg)
        with open(log_path + ".status", "w") as sf:
            sf.write("1")
        return 1
        
    return 0

# Setup test variant directory
VariantDir(gaze_variant_dir + "/tests", "tests", duplicate=0)

# Add doctest and stb include path to core_env
core_env.Append(CPPPATH=["#thirdparty/doctest", "#thirdparty/stb", "#thirdparty/godot-cpp/include", "#thirdparty/godot-cpp/gen/include"])

# Configure native test target binaries (only on non-web/non-javascript platforms)
if env["platform"] != "javascript":
    test_objs = []
    
    # 1. Compile core sources using core_env
    for f in Glob("#src/core/*.cpp"):
        rel_path = os.path.relpath(f.abspath, Dir("#src").abspath)
        obj_file = "#" + os.path.join(gaze_variant_dir, rel_path.replace(".cpp", core_env["OBJSUFFIX"]))
        test_objs.append(core_env.Object(target=obj_file, source=f))
        
    # 2. Compile tests/test_main.cpp using core_env
    test_main_obj = core_env.Object(
        target="#" + os.path.join(gaze_variant_dir, "tests/test_main" + core_env["OBJSUFFIX"]),
        source="#tests/test_main.cpp"
    )
    test_objs.append(test_main_obj)
    
    # 3. Include native tests on non-web platforms
    native_excludes = [
        "godot_camera.cpp",
        "gaze_processors.cpp",
        "gaze_tracker_native.cpp",
        "vision_server.cpp",
        "wmf_camera.cpp"
    ]
    for f in Glob("#src/native/*.cpp"):
        filename = os.path.basename(str(f))
        if filename in native_excludes:
            continue
        if filename.endswith(".fallback.cpp"):
            continue
        rel_path = os.path.relpath(f.abspath, Dir("#src").abspath)
        obj_file = "#" + os.path.join(gaze_variant_dir, rel_path.replace(".cpp", core_env["OBJSUFFIX"]))
        test_objs.append(core_env.Object(target=obj_file, source=f))
        
    if env["platform"] != "windows":
        for f in Glob("#src/native/*.fallback.cpp"):
            rel_path = os.path.relpath(f.abspath, Dir("#src").abspath)
            obj_file = "#" + os.path.join(gaze_variant_dir, rel_path.replace(".fallback.cpp", core_env["OBJSUFFIX"]))
            test_objs.append(core_env.Object(target=obj_file, source=f))

    if env["platform"] == "windows":
        for f in Glob("#src/windows/*.cpp"):
            rel_path = os.path.relpath(f.abspath, Dir("#src").abspath)
            obj_file = "#" + os.path.join(gaze_variant_dir, rel_path.replace(".cpp", core_env["OBJSUFFIX"]))
            test_objs.append(core_env.Object(target=obj_file, source=f))
            
    if env["platform"] in ["macos", "ios"]:
        for f in Glob("#src/native/*.mm"):
            rel_path = os.path.relpath(f.abspath, Dir("#src").abspath)
            obj_file = "#" + os.path.join(gaze_variant_dir, rel_path.replace(".mm", core_env["OBJSUFFIX"]))
            test_objs.append(core_env.Object(target=obj_file, source=f))
            
        test_objs.append(core_env.Object(source="#" + os.path.join(gaze_variant_dir, "thirdparty_objc/ort_value.mm")))
        test_objs.append(core_env.Object(source="#" + os.path.join(gaze_variant_dir, "thirdparty_objc/ort_enums.mm")))
        test_objs.append(core_env.Object(source="#" + os.path.join(gaze_variant_dir, "thirdparty_objc/error_utils.mm")))
        
    test_objs.append(core_env.Object(
        target="#" + os.path.join(gaze_variant_dir, "tests/test_native" + core_env["OBJSUFFIX"]),
        source="#tests/test_native.cpp"
    ))
    
    exe_suffix = ".exe" if env["platform"] == "windows" else ""
    target_test_bin = "#" + f"build/tests/test_native.{platform_str}.{env['arch']}{exe_suffix}"
    test_program = core_env.Program(target=target_test_bin, source=test_objs)

    # Build benchmark test executable
    benchmark_objs = [obj for obj in test_objs if "test_native" not in str(obj)]
    benchmark_objs.append(core_env.Object(
        target="#" + os.path.join(gaze_variant_dir, "tests/test_benchmark" + core_env["OBJSUFFIX"]),
        source="#tests/test_benchmark.cpp"
    ))
    
    target_benchmark_bin = "#" + f"build/tests/test_benchmark.{platform_str}.{env['arch']}{exe_suffix}"
    benchmark_program = core_env.Program(target=target_benchmark_bin, source=benchmark_objs)
    
    # Build stress test cast
    stress_test_objs = [
        env.Object(target="#" + os.path.join(gaze_variant_dir, "tests/stress_test_cast" + env["OBJSUFFIX"]), source="#tests/stress_test_cast.cpp")
    ]
    stress_target_test_bin = "#" + f"build/tests/stress_test_cast.{platform_str}.{env['arch']}{exe_suffix}"
    stress_test_program = env.Program(target=stress_target_test_bin, source=stress_test_objs)

    # Codesigning on macOS
    if env["platform"] == "macos":
        core_env.AddPostAction(test_program, "codesign -s - --force $TARGET")
        core_env.AddPostAction(benchmark_program, "codesign -s - --force $TARGET")
        env.AddPostAction(stress_test_program, "codesign -s - --force $TARGET")

    # Native test runner target
    native_run = env.Command(
        "build/tests/logs/tests.native.log",
        [test_program],
        Action(run_command_and_log, varlist=["TEST_CMD"]),
        TEST_CMD=[test_program[0].abspath]
    )
    env.AlwaysBuild(native_run)
    env.Alias("tests/native", native_run)

    # Benchmark test runner target
    benchmark_run = env.Command(
        "build/tests/logs/tests.benchmark.log",
        [benchmark_program],
        Action(run_command_and_log, varlist=["TEST_CMD"]),
        TEST_CMD=[benchmark_program[0].abspath]
    )
    env.AlwaysBuild(benchmark_run)
    env.Alias("tests/benchmark", benchmark_run)

    # Native stress test runner target
    stress_run = env.Command(
        "build/tests/logs/tests.native.stress.log",
        [stress_test_program],
        Action(run_command_and_log, varlist=["TEST_CMD"]),
        TEST_CMD=[stress_test_program[0].abspath]
    )
    env.AlwaysBuild(stress_run)
    env.Alias("tests/native/stress", stress_run)

# Python unit test target
python_run = env.Command(
    "build/tests/logs/tests.python.log",
    [],
    Action(run_command_and_log, varlist=["TEST_CMD"]),
    TEST_CMD=["pytest", "tests/gaze_test.py", "--junitxml=build/tests/artifacts/python_report.xml"]
)
env.AlwaysBuild(python_run)
env.Alias("tests/python", python_run)

# Godot headless E2E test target
godot_headless_run = env.Command(
    "build/tests/logs/tests.godot.headless.log",
    [library],
    Action(run_command_and_log, varlist=["TEST_CMD"]),
    TEST_CMD=["./scripts/godot.sh", "--headless", "addons/godot-gaze/tests/headless_test.tscn"]
)
env.AlwaysBuild(godot_headless_run)
env.Alias("tests/godot/headless", godot_headless_run)

# Godot windowed E2E test target
godot_windowed_run = env.Command(
