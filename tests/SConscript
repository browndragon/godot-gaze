    TEST_CMD=["./scripts/godot.sh", "--no-auto", "--rendering-method", "mobile", "-s", "addons/godot-gaze/tests/windowed_test.gd"]
)
env.AlwaysBuild(godot_windowed_run)
env.Alias("tests/godot/windowed", godot_windowed_run)

# Godot camera exit E2E test target
godot_camera_exit_run = env.Command(
