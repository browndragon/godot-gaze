    "build/tests/logs/tests.web.log",
    [],
    Action(run_command_and_log, varlist=["TEST_CMD"]),
    TEST_CMD=["node", "tools/run_web_tests.js"]
)
env.AlwaysBuild(web_run)

web_sidecar_run = env.Command(
    "build/tests/logs/tests.web.sidecar.log",
    [],
    Action(run_command_and_log, varlist=["TEST_CMD"]),
    TEST_CMD=["node", "tools/run_sidecar_gaze_tests.js"]
)
env.AlwaysBuild(web_sidecar_run)

env.Alias("tests/web", [web_run, web_sidecar_run])

# Android E2E test target
android_run = env.Command(
    "build/tests/logs/tests.android.log",
    [],
    Action(run_command_and_log, varlist=["TEST_CMD"]),
    TEST_CMD=["/usr/bin/env", "bash", "scripts/run_android_tests.sh"]
)
env.AlwaysBuild(android_run)
env.Alias("tests/android", android_run)

# Managed Android E2E test target
android_managed_run = env.Command(
    "build/tests/logs/tests.android_managed.log",
    [],
    Action(run_command_and_log, varlist=["TEST_CMD"]),
    TEST_CMD=["/usr/bin/env", "bash", "scripts/run_android_tests_managed.sh"]
